---
import ThemeToggle from './ThemeToggle.astro';
import LangSwitcher from './LangSwitcher.astro';
import { getT, localizedPath, DEFAULT_LANG, type Lang } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = DEFAULT_LANG } = Astro.props;
const t = getT(lang);
const base = localizedPath(lang);
const apiBaseUrl = (import.meta.env.PUBLIC_VYOMAR_API_URL || 'http://localhost:8084').replace(/\/+$/, '');
const brandChannel = import.meta.env.PUBLIC_BRAND_CHANNEL;
---
<header
  data-site-header
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300"
>
  <div class="mx-auto flex h-18 max-w-6xl items-center justify-between gap-3 px-4 sm:px-8">
    <a href={base} class="group flex min-w-0 items-center gap-2.5 no-underline">
      <img src="/logo.svg" alt="" width="36" height="36" class="h-9 w-9 shrink-0 transition group-hover:scale-105" />
      <span class="font-serif text-lg font-bold tracking-tight text-ink">Vyom <span class="text-accent not-italic">AR</span></span>
      {brandChannel && (
        <span class="rounded-full border border-accent/40 bg-accent/10 px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.08em] text-accent">{brandChannel}</span>
      )}
    </a>

    <nav class="flex shrink-0 items-center gap-1 sm:gap-2 md:gap-4">
      <a href={`${base}#features`} class="hidden rounded-full px-3 py-2 text-sm font-medium text-dim no-underline transition hover:text-ink md:inline-flex">{t.nav.features}</a>
      <a href={`${base}#screens`} class="hidden rounded-full px-3 py-2 text-sm font-medium text-dim no-underline transition hover:text-ink md:inline-flex">{t.nav.app}</a>
      <a href={`${base}#api`} class="hidden rounded-full px-3 py-2 text-sm font-medium text-dim no-underline transition hover:text-ink md:inline-flex">{t.nav.api}</a>
      <LangSwitcher lang={lang} />
      <ThemeToggle />
      <a href={`${apiBaseUrl}/v1/panchang?lat=12.9716&lon=77.5946`} class="btn btn-primary px-4 py-2 text-sm">{t.nav.tryApi}</a>
    </nav>
  </div>
</header>

<style>
  [data-site-header].is-scrolled {
    border-bottom-color: var(--rule);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(18px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.18);
  }
</style>
