---
import { getT, localizedPath, DEFAULT_LANG, type Lang } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = DEFAULT_LANG } = Astro.props;
const t = getT(lang);
const base = localizedPath(lang);
const apiBaseUrl = (import.meta.env.PUBLIC_VYOMAR_API_URL || 'http://localhost:8084').replace(/\/+$/, '');
---
<footer class="relative mt-24 border-t px-4 py-16" style="border-color: var(--rule)">
  <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-[1.6fr_1fr_1fr_1fr]">
    <div>
      <a href={base} class="flex items-center gap-2.5 no-underline">
        <img src="/logo.svg" alt="" width="36" height="36" class="h-9 w-9" />
        <span class="font-serif text-lg font-bold tracking-tight text-ink">Vyom <span class="text-accent">AR</span></span>
      </a>
      <p class="mt-4 max-w-sm text-sm leading-7 text-dim">{t.footer.tagline}</p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-faint">{t.footer.explore}</p>
      <ul class="mt-4 space-y-3 text-sm">
        <li><a href={`${base}#features`} class="text-dim no-underline transition hover:text-accent">{t.nav.features}</a></li>
        <li><a href={`${base}#screens`} class="text-dim no-underline transition hover:text-accent">{t.nav.app}</a></li>
        <li><a href={`${base}#api`} class="text-dim no-underline transition hover:text-accent">{t.nav.api}</a></li>
      </ul>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-faint">{t.footer.developers}</p>
      <ul class="mt-4 space-y-3 text-sm">
        <li><a href={`${apiBaseUrl}/v1/panchang?lat=12.9716&lon=77.5946`} class="text-dim no-underline transition hover:text-accent">{t.footer.panchangEndpoint}</a></li>
        <li><a href={`${apiBaseUrl}/health`} class="text-dim no-underline transition hover:text-accent">{t.footer.apiStatus}</a></li>
      </ul>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-faint">{t.footer.legal}</p>
      <ul class="mt-4 space-y-3 text-sm">
        <li><a href="/privacy/" class="text-dim no-underline transition hover:text-accent">{t.footer.privacy}</a></li>
        <li><a href="/terms/" class="text-dim no-underline transition hover:text-accent">{t.footer.terms}</a></li>
      </ul>
    </div>
  </div>

  <div class="mx-auto mt-12 flex max-w-6xl flex-col items-center justify-between gap-3 border-t pt-7 text-sm text-faint sm:flex-row" style="border-color: var(--rule)">
    <p>&copy; <span id="copyright-year">2026</span> CoderMana Technologies Private Limited.</p>
    <p class="inline-flex items-center gap-1.5">
      {t.footer.made} <i data-lucide="heart" class="h-4 w-4 text-accent"></i>
    </p>
  </div>
</footer>
